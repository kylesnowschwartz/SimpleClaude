{
  "description": "SimpleClaude hook configuration for auto-formatting, lint checks, and tool monitoring",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Running SimpleClaude format and lint checks...",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/entrypoints/stop.rb"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Checking GitHub fetch guidance...",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/entrypoints/pre_tool_use.rb"
          }
        ]
      }
    ]
  }
}
